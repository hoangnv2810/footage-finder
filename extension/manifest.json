{
  "manifest_version": 3,
  "name": "Footage Finder Importer",
  "version": "0.1.0",
  "description": "Import Qwen chat video analysis into Footage Finder.",
  "permissions": ["activeTab", "tabs", "clipboardWrite", "scripting"],
  "host_permissions": [
    "https://chat.qwen.ai/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_title": "Footage Finder Importer",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.qwen.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
